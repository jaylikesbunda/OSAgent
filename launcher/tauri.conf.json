{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSAgent Launcher",
  "version": "0.1.0",
  "identifier": "com.osagent.launcher",
  "build": {
    "beforeDevCommand": "cargo build",
    "frontendDist": "src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OSAgent Launcher",
        "width": 700,
        "height": 620,
        "minWidth": 620,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/thinking-indicator.png",
      "icons/thinking-indicator.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "2024 OSA Contributors",
    "category": "DeveloperTool",
    "shortDescription": "OSAgent Launcher",
    "longDescription": "Modern launcher for OSAgent AI assistant with system tray and window management",
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
